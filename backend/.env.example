# ── Base de datos ────────────────────────────────────────────────────────────
# Con Docker Compose el host es 'db' (nombre del servicio).
# Sin Docker, cámbialo a 'localhost'.
DATABASE_URL=postgresql://postgres:hestia_pass@db:5432/hestia_db

# ── JWT ──────────────────────────────────────────────────────────────────────
# Genera tu clave con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=reemplaza_esto_con_una_clave_segura
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Admin inicial ─────────────────────────────────────────────────────────────
# Credenciales del primer usuario administrador.
# NUNCA uses valores obvios en producción.
ADMIN_EMAIL=admin@hestia.cl
ADMIN_PASSWORD=reemplaza_esto_con_una_password_segura

# ── API Docs ──────────────────────────────────────────────────────────────────
# Habilita /docs y /redoc. Usar true SOLO en desarrollo local.
# En producción debe permanecer en false (valor por defecto).
DOCS_HABILITADOS=false

# ── CORS ───────────────────────────────────────────────────────────────────
# Origen permitido para peticiones CORS. En LAN, cambiar por la IP real del servidor.
# Ej: CORS_ORIGIN=http://192.168.1.50:3000
CORS_ORIGIN=http://localhost:3000
