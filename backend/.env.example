# ─── Base de datos ───────────────────────────────────────────────────────────
# IMPORTANTE: cuando usas Docker Compose, el host es 'db' (nombre del servicio).
# Si corres la API localmente sin Docker, cámbialo a 'localhost'.
DATABASE_URL=postgresql://postgres:hestia_pass@db:5432/hestia_db

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Genera tu clave con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=reemplaza_esto_con_una_clave_segura
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
