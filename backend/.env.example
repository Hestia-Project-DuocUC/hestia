# ── Base de datos ────────────────────────────────────────────────────────────
# Con Docker Compose el host es 'db' (nombre del servicio).
# Sin Docker, cámbialo a 'localhost'.
DATABASE_URL=postgresql://postgres:hestia_pass@db:5432/hestia_db

# ── JWT ──────────────────────────────────────────────────────────────────────
# Genera tu clave con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=reemplaza_esto_con_una_clave_segura
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Admin inicial ─────────────────────────────────────────────────────────────
# Credenciales del primer usuario administrador.
# NUNCA uses valores obvios en producción.
ADMIN_EMAIL=admin@hestia.cl
ADMIN_PASSWORD=reemplaza_esto_con_una_password_segura

# ── API Docs ──────────────────────────────────────────────────────────────────
# Habilita /docs y /redoc. Usar true SOLO en desarrollo local.
# En producción debe permanecer en false (valor por defecto).
DOCS_HABILITADOS=false

# ── CORS ───────────────────────────────────────────────────────────────────
# Origen permitido para peticiones CORS. En LAN con HTTPS: https://192.168.1.50
CORS_ORIGIN=http://localhost:3000

# ── Recuperacion de contrasena (SMTP) ──────────────────────────────────────
# Dejar SMTP_HOST vacio deshabilita el envio; el enlace se loguea en consola.
# Ver logs con: docker compose logs api | grep "Recovery link"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@hestia.local
SMTP_TLS=true

# ── URL base del frontend ──────────────────────────────────────────────────
# Usada para generar el enlace de recuperacion de contrasena.
# En LAN con nginx HTTPS: https://192.168.1.50
BASE_URL=http://localhost:3000

# ── Alertas de acceso fuera de horario ────────────────────────────────────
# Rango horario en UTC. Logins fuera de este rango generan ALERTA_ACCESO_FUERA_HORARIO.
HORARIO_INICIO_H=8
HORARIO_FIN_H=20
